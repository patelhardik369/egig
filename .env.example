# Copy to .env and tune.  All values are optional; sane defaults live in bot/config.py.
# Paper trading needs NO API keys (all endpoints used are public/read-only).

# ---- mode / universe ----
MODE=paper
COINS=btc,sol,xrp,eth      # all four; conditional on choppiness, ETH has the HIGHEST reversal (15.9%)

# ---- strategy (defaults = research-validated edge; see VPS post-mortem) ----
# Core filter: bet the losing side only if the underlying is still within MAX_LEAD_PCT of the open.
MAX_LEAD_PCT=0.04          # %  (tightening did NOT help in the post-mortem; choppiness is the real filter)
MIN_LEAD_PCT=0.003         # %  (ensure a real loser exists)
# THE selection brain: smooth windows (cross<6) reversed 0/121 on the VPS run; choppy ones carry the edge.
MIN_CROSSINGS=6            # require >=6 crossings of the open (8-10 = higher win-rate / fewer trades)
ENTRY_HI_S=12              # start acting this many seconds before close
ENTRY_LO_S=3               # never FILL with fewer than this many seconds left (re-checked after odds fetch)
MAX_ENTRY_PRICE=0.03       # only fill the loser at <= 3c
MIN_ENTRY_PRICE=0.005
STAKE_USD=1               # $ per window
MAX_FILLS_PER_WINDOW=1

# ---- risk guard (prevents the VPS-style bankroll wipeout) ----
MAX_DRAWDOWN_PCT=25        # halt NEW entries after losing this % of starting cash (100 = disabled)

# ---- engine ----
STARTING_CASH=1000
SAMPLE_INTERVAL_S=1.0
SETTLE_BUFFER_S=20         # wait after close before polling resolution
OPEN_SNAP_TOL_S=5
LOG_LEVEL=INFO

# ---- live odds (real-time websocket) ----
USE_WEBSOCKET=true            # stream actual Polymarket odds from the CLOB market channel
WS_SUBSCRIBE_LEAD_S=120       # subscribe a window's tokens this many seconds before close
WS_STALE_S=12                 # treat a streamed quote older than this as stale (-> REST fallback)
USE_OFFICIAL_CLIENT=true      # use py-clob-client for resolution + REST book fallback
CHAIN_ID=137

# ---- hosts (override if geo-blocked) ----
BINANCE_HOST=https://data-api.binance.vision
GAMMA_HOST=https://gamma-api.polymarket.com
CLOB_HOST=https://clob.polymarket.com
CLOB_WS_HOST=wss://ws-subscriptions-clob.polymarket.com/ws/market
# DATA_DIR=./data

# ---- live trading (NOT used in paper mode; placeholders for a future executor) ----
# POLY_PRIVATE_KEY=
# POLY_API_KEY=
# POLY_API_SECRET=
# POLY_API_PASSPHRASE=
# POLY_FUNDER_ADDRESS=
